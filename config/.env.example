# === Modèle de configuration ===
# Copier ce fichier en "config/.env" et remplir les valeurs réelles.
# Le fichier .env est gitignoré : il ne sera JAMAIS poussé sur GitHub.

# Token Hugging Face (requis pour la diarisation pyannote)
# Obtenir sur : https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèle Whisper par défaut (tiny | base | small | medium | large-v3)
WHISPER_MODEL=large-v3

# Langue par défaut des entretiens
WHISPER_LANGUAGE=fr

# Périphérique de calcul (cpu | cuda)
WHISPER_DEVICE=cpu

# Type de calcul (int8 pour CPU, float16 pour GPU NVIDIA)
WHISPER_COMPUTE_TYPE=int8

# Modèle d'empreinte vocale pour la réconciliation des locuteurs (ia reconcilier)
# Défaut : speechbrain/spkrec-ecapa-voxceleb (repli auto sur pyannote/embedding).
# Décommenter pour surcharger.
# EMBEDDING_MODEL=speechbrain/spkrec-ecapa-voxceleb
