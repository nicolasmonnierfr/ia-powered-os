# === Secrets (JAMAIS dans Git) ===
config/.env
*.env
!config/.env.example

# === Données sensibles (audios, transcriptions, sorties) ===
# On ignore le CONTENU de data/ (audios, transcriptions) mais on conserve
# l'arborescence du pipeline via les .gitkeep, pour qu'elle existe au clone.
data/**
!data/
!data/a_traiter/
!data/en_cours/
!data/transcrit/
!data/a_taguer/
!data/archive/
!data/**/.gitkeep
!data/.gitkeep

# === Environnement Python ===
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt

# === Modèles téléchargés (volumineux, re-téléchargeables) ===
models/
*.bin
*.pt
*.onnx

# === IDE / OS ===
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# === Logs & temporaires ===
*.log
tmp/
temp/
