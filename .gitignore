# === Secrets (JAMAIS dans Git) ===
config/.env
*.env
!config/.env.example

# === Données sensibles (audios, transcriptions, intermédiaires) ===
# data/ ne contient que des intermédiaires (data/.chunks/) : tout est ignoré,
# on conserve seulement le dossier vide via .gitkeep.
data/**
!data/
!data/.gitkeep

# === Environnement Python ===
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt

# === Modèles téléchargés (volumineux, re-téléchargeables) ===
models/
*.bin
*.pt
*.onnx

# === IDE / OS ===
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# === Logs & temporaires ===
*.log
tmp/
temp/

# Archives du repo (artefacts, jamais versionnés)
*.zip
